{
  "name": "quillon",
  "version": "1.0.0",
  "description": "Quillon — Interactive Fiction Workbench for ChoiceScript writers",
  "author": "Quillon",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.quillon.app",
    "productName": "Quillon",
    "copyright": "Copyright © 2025 Quillon",
    "icon": "build/icon.ico",
    "forceCodeSigning": false,
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "build/**/*",
      "landing.html",
      "package.json"
    ],
    "extraResources": [
      { "from": "build/", "to": "build/" }
    ],
    "win": {
      "sign": false,
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Quillon"
    }
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.1.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  }
}
